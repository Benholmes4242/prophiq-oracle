# Example env vars. Copy values into .env (committed; public-safe) or
# .env.local (gitignored; for sensitive overrides).

# Supabase (public-by-design; protected by RLS).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public base URL for OG cards, sitemap, and robots.txt.
# Set both to https://prophiq.io once DNS is pointed at the production domain.
# Defaults to the Lovable preview URL if unset (see src/lib/publicUrl.ts).
# VITE_* is exposed to the client at build time; PUBLIC_* is read at runtime
# by server handlers. Set both to the same value.
VITE_PUBLIC_URL=https://prophiq-opinion-nexus.lovable.app
PUBLIC_BASE_URL=https://prophiq-opinion-nexus.lovable.app
